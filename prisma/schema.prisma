generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  is_active  Boolean  @default(false)
  role       Role     @default(PATIENT)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  admin      Admin?
  doctor     Doctor?
  patient    Patient?
}

model Admin {
  id          Int          @id @default(autoincrement())
  user_id     Int          @unique
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  user        User         @relation(fields: [user_id], references: [id])
  departments Department[]
  doctors     Doctor[]
}

model Patient {
  id         Int             @id @default(autoincrement())
  user_id    Int             @unique
  hn_number  String          @unique
  citizen_id String          @unique
  phone_no   String          @unique
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  user       User            @relation(fields: [user_id], references: [id])
  info       Patient_Info?
  vitals     Patient_Vital[]
  results    Lab_Result[]
}

model Patient_Info {
  id            Int        @id @default(autoincrement())
  gender        Gender?
  blood_type    BloodType?
  date_of_birth DateTime?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  patient_id    Int        @unique
  patient       Patient    @relation(fields: [patient_id], references: [id])
}

model Patient_Vital {
  id         Int      @id @default(autoincrement())
  patient_id Int
  height     Float?
  weight     Float?
  bmi        Float?
  systolic   Float?
  diastolic  Float?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  patient    Patient  @relation(fields: [patient_id], references: [id])
}

model Doctor {
  id              Int              @id @default(autoincrement())
  user_id         Int              @unique
  department_id   Int
  experience      Int
  phone_no        String
  title           String?
  created_by      Int?
  admin           Admin?           @relation(fields: [created_by], references: [id])
  department      Department       @relation(fields: [department_id], references: [id])
  user            User             @relation(fields: [user_id], references: [id])
  specializations Specialization[] @relation("DoctorToSpecialization")
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  created_by  Int?
  admin       Admin?   @relation(fields: [created_by], references: [id])
  doctors     Doctor[]
}

model Specialization {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  doctors    Doctor[] @relation("DoctorToSpecialization")
}

model Lab_Test {
  id   Int    @id @default(autoincrement())
  name String @unique

  items   Lab_Test_Item[]
  results Lab_Result[]
}

model Lab_Test_Item {
  id              Int     @id @default(autoincrement())
  lab_test_id     Int
  name            String
  unit            String?
  normal_range    String?
  gender_specific Boolean
  value_type      String

  lab_test Lab_Test     @relation(fields: [lab_test_id], references: [id])
  results  Lab_Result[]
}

model Lab_Result {
  id                Int      @id @default(autoincrement())
  patient_id        Int
  lab_test_id       Int
  lab_test_item_id  Int
  recommendation_id Int? // need to make this to required
  result            Float
  status            String
  date              DateTime @default(now())

  patient        Patient           @relation(fields: [patient_id], references: [id])
  lab_test       Lab_Test          @relation(fields: [lab_test_id], references: [id])
  lab_test_item  Lab_Test_Item     @relation(fields: [lab_test_item_id], references: [id])
  recommendation Recommendation?   @relation(fields: [recommendation_id], references: [id])
  prediction     Model_Prediction?
}

model Model_Prediction {
  id                   Int        @id @default(autoincrement())
  lab_result_id        Int        @unique
  lab_result           Lab_Result @relation(fields: [lab_result_id], references: [id])
  //lab_test_id          Int
  model_recommendation String
  probability          String
}

model Recommendation {
  id                       Int          @id @default(autoincrement())
  lab_result_id            Int
  generated_recommendation String       @db.Text
  doctor_recommendation    String?      @db.Text
  date                     DateTime     @default(now())
  status                   String
  lab_results              Lab_Result[]
}

enum Role {
  PATIENT
  ADMIN
  DOCTOR
}

enum Gender {
  MALE
  FEMALE
}

enum BloodType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
}
