generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String
  is_active  Boolean  @default(false)
  role       Role     @default(PATIENT)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  admin      Admin?
  doctor     Doctor?
  patient    Patient?
}

model Admin {
  id          Int          @id @default(autoincrement())
  user_id     Int          @unique
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  user        User         @relation(fields: [user_id], references: [id])
  departments Department[]
  doctors     Doctor[]
}

model Patient {
  id         Int             @id @default(autoincrement())
  user_id    Int             @unique
  hn_number  String          @unique
  citizen_id String          @unique
  phone_no   String          @unique
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  user       User            @relation(fields: [user_id], references: [id])
  info       Patient_Info?
  vitals     Patient_Vital[]
}

model Patient_Info {
  id            Int        @id @default(autoincrement())
  gender        Gender?
  blood_type    BloodType?
  date_of_birth DateTime?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  patient_id    Int        @unique
  patient       Patient    @relation(fields: [patient_id], references: [id])
}

model Patient_Vital {
  id         Int      @id @default(autoincrement())
  patient_id Int
  height     Float?
  weight     Float?
  bmi        Float?
  systolic   Float?
  diastolic  Float?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  patient    Patient  @relation(fields: [patient_id], references: [id])
}

model Doctor {
  id              Int              @id @default(autoincrement())
  user_id         Int              @unique
  department_id   Int
  experience      Int
  phone_no        String
  title           String?
  created_by      Int?
  admin           Admin?           @relation(fields: [created_by], references: [id])
  department      Department       @relation(fields: [department_id], references: [id])
  user            User             @relation(fields: [user_id], references: [id])
  specializations Specialization[] @relation("DoctorToSpecialization")
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  created_by  Int?
  admin       Admin?   @relation(fields: [created_by], references: [id])
  doctors     Doctor[]
}

model Specialization {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  doctors    Doctor[] @relation("DoctorToSpecialization")
}

enum Role {
  PATIENT
  ADMIN
  DOCTOR
}

enum Gender {
  MALE
  FEMALE
}

enum BloodType {
  A_POS
  A_NEG
  B_POS
  B_NEG
  O_POS
  O_NEG
  AB_POS
  AB_NEG
}
